<div class="dialog-common">
    <div class="dialog-header">{{localize "DIALOG.COMMON_ROLL"}}</div>
    <div class="dialog-row">
        <div class="form-group stacked dn">
            <label>
                {{localize "DIALOG.DN"}}
            </label>
            <div class="form-fields">
                <select name="difficulty" data-tooltip-direction="LEFT" data-tooltip="{{tooltips.difficulty}}">
                    {{selectOptions difficulties selected=fields.difficulty}}
                </select>
                :
                <select name="complexity" data-tooltip-direction="LEFT" data-tooltip="{{tooltips.complexity}}">
                    {{selectOptions complexities selected=fields.complexity}}
                </select>
            </div>
        </div>
        <div class="form-group stacked">
            <label>{{localize "DIALOG.BONUSDICE"}}</label>
            <div class="form-fields">
                <input name="bonusDice" type="number" value="{{fields.bonusDice}}" />
            </div>
        </div>
        <div class="form-group stacked">
            <label>{{localize "DIALOG.BONUSFOCUS"}}</label>
            <div class="form-fields">
                <input name="bonusFocus" name="bonusFocus" type="number" value="{{fields.bonusFocus}}" />
            </div>
        </div>
    </div>
</div>